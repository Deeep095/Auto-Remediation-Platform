    {
      "parameters": {
        "jsCode": "const a = $input.first().json;\nlet s = 'P3', u = 'low', r = false, rt = null;\n\nif (a.environment === 'production') {\n  if (a.metric === 'health_check' && (a.value === 'down' || a.value == 0)) { s = 'P1'; u = 'critical'; r = true; rt = 'restart_service'; }\n  if (a.metric === 'error_rate' && Number(a.value) > 50) { s = 'P1'; u = 'critical'; }\n  if (a.metric === 'cpu_usage' && Number(a.value) > 95) { s = 'P1'; u = 'critical'; r = true; rt = 'scale_up'; }\n}\n\nif (s === 'P3' && a.environment === 'production') {\n  if (a.metric === 'cpu_usage' && Number(a.value) > 80) { s = 'P2'; u = 'high'; }\n  if (a.metric === 'memory_usage' && Number(a.value) > 85) { s = 'P2'; u = 'high'; r = true; rt = 'restart_service'; }\n}\n\nreturn [{ json: { ...a, severity: s, urgency: u, requires_remediation: r, remediation_type: rt } }];"
