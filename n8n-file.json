    {
      "parameters": {
        "jsCode": "let inputJson = $input.first().json;\nlet raw = inputJson.body || inputJson;\n\nif (typeof raw === 'string') {\n    try { raw = JSON.parse(raw); } catch(e) {}\n} else if (raw && Object.keys(raw).length > 0 && Object.keys(raw)[0].includes('\"Type\"')) {\n    try { raw = JSON.parse(Object.keys(raw)[0]); } catch(e) {}\n}\n\nlet parsed = { ...raw };\n\nif (raw.Type === \"Notification\" && raw.Message) {\n    try {\n        let cwData = typeof raw.Message === 'string' ? JSON.parse(raw.Message) : raw.Message;\n        parsed.source = \"cloudwatch\";\n        parsed.service = cwData.AlarmName || \"unknown-alarm\";\n        parsed.message = cwData.NewStateReason || \"Alarm triggered\";\n        \n        if (cwData.NewStateValue === \"ALARM\") {\n            parsed.metric = \"cpu_usage\";\n            parsed.value = 100;\n        }\n        \n        if (cwData.Trigger && cwData.Trigger.Dimensions && cwData.Trigger.Dimensions.length > 0) {\n            parsed.instance_id = cwData.Trigger.Dimensions[0].value;\n        }\n    } catch(e) {\n        parsed.message = \"Failed to parse inner CloudWatch message\";\n    }\n}\n\nreturn [{ json: { \n  alert_id: parsed.alert_id || parsed.id || 'alert_' + Date.now(), \n  source: parsed.source || 'unknown', \n  service: parsed.service || 'untagged', \n  metric: parsed.metric || 'unknown', \n  value: parsed.value !== undefined ? parsed.value : null, \n  threshold: parsed.threshold || null, \n  message: parsed.message || 'No description', \n  environment: parsed.environment || 'production', \n  region: parsed.region || 'us-east-1', \n  instance_id: parsed.instance_id || null, \n  timestamp: parsed.timestamp || new Date().toISOString(),\n  raw_payload: JSON.stringify(raw)\n} }];"
      },
